# Required for stage3 Claude extraction
ANTHROPIC_API_KEY=sk-ant-...

# Recommended for NCBI E-utilities (fallback); free at https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# Optional: shared password for the review app (default: proteobench-review)
REVIEW_TOKEN=proteobench-review

# Optional: Hugging Face dataset freezes (free public storage)
# Hosts both mining releases/ and data-cube cubes/ under one dataset repo.
# Create a write token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...
# PAPER_MINE_HF_REPO=YOUR_USER/proteobench-mining-releases
# PAPER_MINE_RELEASE_BACKEND=huggingface   # or github (mining only)
